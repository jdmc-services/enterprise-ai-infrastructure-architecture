```mermaid
flowchart TD
    subgraph USER["USER ACCESS LAYER"]
        U1[Enterprise User\nBrowser / App Client]
        U2[IdP / SSO / MFA\nAuthentication]
        U3[RBAC Engine\nRole Token Assignment]
    end

    subgraph GATEWAY["AI GATEWAY — AI-SVC-DMZ Zone"]
        G1[AI API Gateway\nRate Limiting · Routing]
        G2[Prompt Inspection Engine\nInjection Detection · Input Validation]
        G3[DLP Filter — Input\nSensitive Data Pattern Check]
        G4[Session Logger\nRequest Metadata Capture]
    end

    subgraph RETRIEVAL["RAG RETRIEVAL ENGINE — AI-PROC Zone"]
        R1[Query Embedding Service\nVector Representation]
        R2[Metadata Filter Builder\nRBAC-Aligned Access Filter]
        R3[Vector Database Search\nSemantic Similarity Query]
        R4[Context Assembler\nChunk Ranking · Citation Prep]
    end

    subgraph DATA["AI DATA ZONE — AI-DATA Zone"]
        D1[Vector Database\nApproved Enterprise Knowledge Store]
        D2[Document Metadata Index\nClassification · Owner · Version]
        D3[Raw Document Store\nSource-of-Truth Archives]
    end

    subgraph INGEST["DOCUMENT INGESTION — AI-INGEST Zone"]
        I1[Document Governance\nApproval Workflow Gate]
        I2[Classification Engine\nData Sensitivity Tagging]
        I3[Parser + Chunker\nDocument Processing]
        I4[Embedding Loader\nVector Store Writer]
    end

    subgraph LLM["LLM INFERENCE — AI-PROC Zone"]
        L1[System Prompt\nVersion-Controlled · Immutable]
        L2[Approved LLM Endpoint\nPrivate or Governed API]
        L3[Output Validator\nDLP · Quality · Confidence Scoring]
        L4[Response Formatter\nCitation Inclusion · Disclaimer]
    end

    subgraph OBS["OBSERVABILITY — AI-MGMT Zone"]
        O1[Structured Log Aggregator]
        O2[Enterprise SIEM\nCorrelation · Alerting · Audit]
        O3[Metrics and Tracing Platform]
        O4[Observability Dashboard]
    end

    subgraph NET["NETWORK FOUNDATION"]
        N1[VLAN Segmentation\nAI-SVC-DMZ · AI-PROC · AI-DATA · AI-MGMT]
        N2[Firewall Zone Policy\nDeny-All Default · Permit by Exception]
        N3[SD-WAN Edge\nBranch Connectivity]
        N4[Private Cloud Interconnect]
        N5[CLINICAL ZONE\nFULLY ISOLATED — NO AI CONNECTIVITY]
    end

